# Default: normalise text on commit, native EOL on checkout
* text=auto

# Windows-only scripts MUST keep CRLF — cmd.exe rejects LF-only batch files
# and PowerShell behaves unpredictably with bare LF on Windows.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.psm1  text eol=crlf

# Unix-only scripts MUST keep LF — Windows-edited shell scripts otherwise
# break in WSL2 with "/usr/bin/env: 'bash\r': No such file" errors.
*.sh    text eol=lf

# Source and config: keep LF (works on every platform)
*.py    text eol=lf
*.rs    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.gguf  binary
*.bin   binary
*.zip   binary
*.exe   binary
*.dll   binary
